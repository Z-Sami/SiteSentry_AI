# SiteSentry Git Attributes
# Normalize line endings across all platforms

# Auto detect text files and normalize line endings to LF
* text=auto

# Source code
*.py text eol=lf
*.ino text eol=lf
*.sh text eol=lf

# Config & data
*.yaml text eol=lf
*.yml text eol=lf
*.json text eol=lf
*.txt text eol=lf
*.md text eol=lf
*.launch text eol=lf

# Binary files
*.jpg binary
*.jpeg binary
*.png binary
*.gif binary
*.dxf binary
*.pdf binary
