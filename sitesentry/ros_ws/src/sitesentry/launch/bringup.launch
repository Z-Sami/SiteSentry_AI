<?xml version="1.0"?>
<!--
  SiteSentry Bringup Launch File
  =============================
  Starts all ROS nodes for autonomous inspection mission.
  
  Includes:
    - RPLIDAR A1 (lidar)
    - AMCL (localization)
    - move_base (navigation)
    - rosserial (Arduino communication)
    - SiteSentry State Machine Node (mission controller)
  
  Usage:
    roslaunch sitesentry bringup.launch map_file:=/path/to/map.yaml
    roslaunch sitesentry bringup.launch map_file:=/path/to/map.yaml robot:=my_robot
-->

<launch>
  <!-- Arguments -->
  <arg name="map_file" default="$(find sitesentry)/../../../map.yaml" doc="Path to static map file"/>
  <arg name="robot" default="sitesentry" doc="Robot name / tf_prefix"/>
  <arg name="lidar_port" default="/dev/ttyUSB0" doc="RPLIDAR serial port"/>
  <arg name="arduino_port" default="/dev/ttyUSB1" doc="Arduino serial port"/>
  <arg name="rviz" default="false" doc="Launch RViz visualization"/>
  
  <!-- Set tf_prefix -->
  <param name="tf_prefix" value="$(arg robot)"/>
  
  <!-- Static Map Server -->
  <node pkg="map_server" type="map_server" name="map_server" args="$(arg map_file)">
    <param name="frame_id" value="map"/>
  </node>
  
  <!-- RPLIDAR A1 (USB Lidar) -->
  <node pkg="rplidar_ros" type="rplidarNode" name="rplidar">
    <param name="serial_port" value="$(arg lidar_port)"/>
    <param name="serial_baudrate" value="115200"/>
    <param name="frame_id" value="lidar_link"/>
    <param name="inverted" value="false"/>
    <param name="angle_compensate" value="true"/>
  </node>
  
  <!-- TF Tree: base_link → lidar_link -->
  <node pkg="tf" type="static_transform_publisher" name="base_to_lidar_tf" 
        args="0 0 0.1 0 0 0 base_link lidar_link 100"/>
  
  <!-- Robot State Publisher (publish tf for robot frame) -->
  <node pkg="robot_state_publisher" type="robot_state_publisher" name="robot_state_publisher">
    <param name="robot_description" value="$(find sitesentry)/../../../urdf/sitesentry.urdf"/>
    <param name="publish_frequency" value="50"/>
  </node>
  
  <!-- AMCL (Adaptive Monte Carlo Localization) -->
  <node pkg="amcl" type="amcl" name="amcl">
    <param name="use_map_topic" value="true"/>
    <param name="odom_frame_id" value="odom"/>
    <param name="base_frame_id" value="base_link"/>
    <param name="global_frame_id" value="map"/>
    
    <!-- Initial pose estimate -->
    <param name="initial_pose_x" value="0.0"/>
    <param name="initial_pose_y" value="0.0"/>
    <param name="initial_pose_a" value="0.0"/>
    
    <!-- Odometry model (skid-steer) -->
    <param name="odom_model_type" value="diff-corrected"/>
    <param name="odom_alpha1" value="0.2"/>
    <param name="odom_alpha2" value="0.2"/>
    <param name="odom_alpha3" value="0.2"/>
    <param name="odom_alpha4" value="0.2"/>
    
    <!-- Lidar model -->
    <param name="laser_max_beams" value="30"/>
    <param name="laser_z_hit" value="0.5"/>
    <param name="laser_z_short" value="0.05"/>
    <param name="laser_z_max" value="0.05"/>
    <param name="laser_z_rand" value="0.5"/>
    <param name="laser_sigma_hit" value="0.2"/>
    
    <!-- Particle filter -->
    <param name="min_particles" value="500"/>
    <param name="max_particles" value="5000"/>
    <param name="pf_z_good" value="0.9"/>
    <param name="pf_z_total" value="0.1"/>
  </node>
  
  <!-- move_base Navigation Stack -->
  <node pkg="move_base" type="move_base" name="move_base">
    <!-- Frames -->
    <param name="global_costmap/global_frame" value="map"/>
    <param name="global_costmap/robot_base_frame" value="base_link"/>
    <param name="local_costmap/global_frame" value="odom"/>
    <param name="local_costmap/robot_base_frame" value="base_link"/>
    
    <!-- Local/Global Costmap Configs -->
    <rosparam file="$(find sitesentry)/config/costmap.yaml" command="load" ns="global_costmap"/>
    <rosparam file="$(find sitesentry)/config/costmap.yaml" command="load" ns="local_costmap"/>
    
    <!-- Base Local Planner (trajectory rollout) -->
    <param name="base_local_planner" value="base_local_planner/TrajectoryPlannerROS"/>
    <rosparam file="$(find sitesentry)/config/base_local_planner.yaml" command="load"/>
    
    <!-- Global Planner -->
    <param name="base_global_planner" value="carrot_planner/CarrotPlanner"/>
  </node>
  
  <!-- rosserial (Arduino Communication) -->
  <node pkg="rosserial_python" type="serial_node.py" name="rosserial_arduino">
    <param name="port" value="$(arg arduino_port)"/>
    <param name="baud" value="57600"/>
  </node>
  
  <!-- SiteSentry State Machine Node -->
  <node pkg="sitesentry" type="state_machine_node.py" name="sitesentry_state_machine" output="screen">
    <param name="mission_file" value="$(find sitesentry)/../../../mission.json"/>
    <param name="serial_port" value="$(arg arduino_port)"/>
    <param name="udp_listen_port" value="5005"/>
  </node>
  
  <!-- Optional: RViz Visualization -->
  <node pkg="rviz" type="rviz" name="rviz" args="-d $(find sitesentry)/config/sitesentry.rviz" 
        if="$(arg rviz)" output="screen"/>
  
  <!-- Logging -->
  <env name="ROS_LOG_DIR" value="/home/pi/.ros/log"/>
  
</launch>
